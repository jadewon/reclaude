<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent for reclaude.
  Edit the paths below to match your clone location, then:

    cp com.github.jadewon.reclaude.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.github.jadewon.reclaude.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.github.jadewon.reclaude</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>REPLACE_ME/reclaude.py</string>
        <string>--port</string>
        <string>9999</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/reclaude.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/reclaude.err</string>
</dict>
</plist>
